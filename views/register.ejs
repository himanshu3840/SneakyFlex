<!DOCTYPE html>
<html lang="en">
<head>
    <title>SneakyFlex Register</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-black text-white min-h-screen flex items-center justify-center relative overflow-hidden">

    <!-- Background Glow -->
    <div class="absolute w-96 h-96 bg-red-600 rounded-full blur-[180px] top-10 left-20 opacity-30"></div>
    <div class="absolute w-96 h-96 bg-blue-600 rounded-full blur-[180px] bottom-10 right-20 opacity-30"></div>

    <!-- Register Box -->
   <div class="w-[460px] bg-white/10 backdrop-blur-xl p-9 rounded-3xl border border-white/20 shadow-2xl relative z-10">

    <h1 class="text-5xl font-black text-center mb-2">
        Sneaky<span class="text-red-500">Flex</span>
    </h1>

    <p class="text-gray-300 text-center mb-8">
        Create your premium sneaker account
    </p>

    <% if(error.length > 0){ %>
        <p class="bg-red-500/20 border border-red-500 text-red-300 p-3 rounded-xl mb-4">
            <%= error %>
        </p>
    <% } %>

    <% if(success.length > 0){ %>
        <p class="bg-green-500/20 border border-green-500 text-green-300 p-3 rounded-xl mb-4">
            <%= success %>
        </p>
    <% } %>

    <form action="/users/register" method="POST" class="space-y-5">

        <input 
            type="text" 
            name="fullname" 
            placeholder="Full Name"
            class="w-full px-5 py-4 rounded-xl bg-black/40 border border-white/20 outline-none focus:border-red-500 transition placeholder:text-gray-400"
        >

        <input 
            type="email" 
            name="email" 
            placeholder="Email"
            class="w-full px-5 py-4 rounded-xl bg-black/40 border border-white/20 outline-none focus:border-red-500 transition placeholder:text-gray-400"
        >

        <input 
            type="password" 
            name="password" 
            placeholder="Password"
            class="w-full px-5 py-4 rounded-xl bg-black/40 border border-white/20 outline-none focus:border-red-500 transition placeholder:text-gray-400"
        >

        <button 
            class="w-full bg-red-600 text-white py-4 rounded-xl font-black hover:bg-red-700 hover:scale-[1.02] transition"
        >
            Register
        </button>
    </form>

   

    <p class="text-center text-gray-300 mt-7">
        Already have an account?
        <a href="/" class="text-red-400 font-bold hover:underline">Login</a>
    </p>

</div>

</body>
</html>