<%
    let subtotal = 0;

    cart.forEach(function(item){
        if(item.discount > 0){
            subtotal += Math.floor(item.price - (item.price * item.discount / 100));
        }
        else{
            subtotal += item.price;
        }
    });

    let platformFee = 20;
    let total = subtotal + platformFee;
%>


<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SneakyFlex | Cart</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="min-h-screen bg-[#050505] text-white overflow-x-hidden">

  <!-- Background Glow -->
  <div class="fixed inset-0 -z-10">
    <div class="absolute -top-32 -left-32 w-[450px] h-[450px] bg-red-600/25 blur-[150px] rounded-full"></div>
    <div class="absolute bottom-0 right-0 w-[450px] h-[450px] bg-blue-600/20 blur-[150px] rounded-full"></div>
  </div>

  <!-- Navbar -->
  <nav class="w-full px-8 py-6 flex items-center justify-between">
    <h1 class="text-2xl font-black tracking-wide">
      Sneaky<span class="text-red-500">Flex</span>
    </h1>

    <div class="flex gap-6 text-sm text-zinc-300">
      <a href="/shop" class="hover:text-white">Shop</a>
      <a href="/cart" class="text-white font-semibold">Cart</a>
      <a href="/users/logout" class="hover:text-red-400">Logout</a>
    </div>
  </nav>

  <!-- Main -->
  <main class="px-6 md:px-16 py-10">

    <div class="mb-10">
      <h2 class="text-4xl md:text-5xl font-black">Your Cart</h2>
      <p class="text-zinc-400 mt-3">Review your selected premium sneakers before checkout.</p>
    </div>

    <div class="grid lg:grid-cols-3 gap-8">

      <!-- Cart Items -->
      <div class="lg:col-span-2 space-y-5">

        <% if (cart && cart.length > 0) { %>

          <% cart.forEach(function(item) { %>
            <div class="bg-white/10 border border-white/10 rounded-3xl p-5 flex flex-col md:flex-row gap-5 items-center shadow-xl">

              <div class="w-full md:w-40 h-40 bg-zinc-900 rounded-2xl overflow-hidden flex items-center justify-center">
                <img 
                    src="data:<%= item.mimetype || 'image/png' %>;base64,<%= item.image %>" 
                    alt="<%= item.name %>" 
                    class="w-full h-full object-cover"
                />
              </div>

              <div class="flex-1 w-full">
                <h3 class="text-2xl font-bold"><%= item.name %></h3>
                <p class="text-zinc-400 mt-1"><%= item.brand || "Premium Sneakers" %></p>

                <div class="mt-4 flex items-center gap-4">
                  <span class="px-4 py-2 rounded-full bg-white/10 text-sm">
                    Qty: <%= item.quantity || 1 %>
                  </span>

                  <span class="px-4 py-2 rounded-full bg-red-500/20 text-red-400 text-sm">
                    Size: <%= item.size || "UK 9" %>
                  </span>
                </div>
              </div>

              <div class="text-right">
                <h4 class="text-2xl font-black">₹<%= item.price %></h4>

                <form action="/cart/remove/<%= item._id %>" method="POST" class="mt-5">
                  <button class="px-5 py-2 rounded-full bg-red-600 hover:bg-red-700 transition text-sm font-semibold">
                    Remove
                  </button>
                </form>
              </div>

            </div>
          <% }) %>

        <% } else { %>

          <div class="bg-white/10 border border-white/10 rounded-3xl p-12 text-center">
            <h3 class="text-3xl font-black">Your cart is empty</h3>
            <p class="text-zinc-400 mt-3">Looks like you haven’t added any sneakers yet.</p>

            <a href="/shop" class="inline-block mt-8 px-8 py-3 rounded-full bg-red-600 hover:bg-red-700 font-bold">
              Continue Shopping
            </a>
          </div>

        <% } %>

      </div>

      <!-- Summary -->
      <div class="bg-white/10 border border-white/10 rounded-3xl p-7 h-fit shadow-2xl">
        <h3 class="text-2xl font-black mb-6">Order Summary</h3>

        <div class="space-y-4 text-zinc-300">
          <div class="flex justify-between">
            <span>Subtotal</span>
            <span>₹<%= subtotal || 0 %></span>
          </div>

          <div class="flex justify-between">
            <span>Shipping</span>
            <span class="text-green-400">Free</span>
          </div>

          <div class="flex justify-between">
            <span>Platform Fee</span>
            <span>₹<%= platformFee || 0 %></span>
          </div>
        </div>

        <div class="border-t border-white/10 my-6"></div>

        <div class="flex justify-between text-2xl font-black">
          <span>Total</span>
          <span>₹<%= total || 0 %></span>
        </div>

        <form action="/orders/create" method="POST" class="mt-8">
          <button 
            class="w-full py-4 rounded-2xl bg-red-600 hover:bg-red-700 transition font-black text-lg"
            <%= cart && cart.length > 0 ? "" : "disabled" %>
          >
            Checkout
          </button>
        </form>

        <a href="/shop" class="block text-center mt-5 text-zinc-400 hover:text-white">
          Continue Shopping
        </a>
      </div>

    </div>
  </main>

</body>
</html>