<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>SneakyFlex | Premium Sneakers</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>



<body class="bg-[#050505] text-white overflow-x-hidden">

<% if(success && success.length > 0){ %>
    <div class="fixed top-24 right-5 bg-green-500 text-white px-6 py-3 rounded-xl shadow-lg z-[9999]">
        <%= success[0] %>
    </div>
<% } %>

    <div class="fixed inset-0 -z-10">
        <div class="absolute top-[-10%] left-[-10%] w-[500px] h-[500px] bg-red-600/30 blur-[160px] rounded-full"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[500px] h-[500px] bg-blue-600/30 blur-[160px] rounded-full"></div>
        <div class="absolute top-[35%] left-[35%] w-[400px] h-[400px] bg-purple-600/20 blur-[180px] rounded-full"></div>
    </div>

    <nav class="w-full px-10 py-6 flex items-center justify-between border-b border-white/10 backdrop-blur-xl bg-black/30 sticky top-0 z-50">
        <h1 class="text-3xl font-black tracking-tight">
            Sneaky<span class="text-red-500">Flex</span>
        </h1>

        <div class="hidden md:flex gap-8 text-sm text-gray-300">
            <a href="/shop" class="hover:text-white">Home</a>
            <a href="/shop" class="hover:text-white">Shop</a>
            <a href="#" class="hover:text-white">Drops</a>
            <a href="/cart" class="hover:text-white">Cart</a>
        </div>

        <div class="flex items-center gap-4">

            <% if(user.isVendor){ %>
                <a 
                    href="/owners/product"
                    class="px-5 py-2 rounded-full border border-green-500 text-green-400 font-bold hover:bg-green-600 hover:text-white transition"
                >
                    Add Product
                </a>
            <% } else { %>
                <a 
                    href="/owners/becomeVendor"
                    class="px-5 py-2 rounded-full border border-red-500 text-red-400 font-bold hover:bg-red-600 hover:text-white transition"
                >
                    Become Vendor
                </a>
            <% } %>

            <a 
                href="/users/logout" 
                class="px-5 py-2 rounded-full bg-white text-black font-bold hover:bg-red-500 hover:text-white transition"
            >
                Logout
            </a>

        </div>
        


    </nav>

    <section class="min-h-[88vh] px-10 flex flex-col lg:flex-row items-center justify-between gap-12">

        <div class="max-w-2xl">
            <p class="text-red-500 font-bold tracking-[0.4em] mb-4">NEW STREET DROP 2026</p>

            <h2 class="text-7xl md:text-8xl font-black leading-none">
                OWN THE <br>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-500 via-white to-blue-500">
                    STREETS
                </span>
            </h2>

            <p class="text-gray-400 mt-8 text-lg max-w-xl">
                Premium sneakers engineered for comfort, dominance and street-level flex.
                Built for people who don't just walk — they arrive.
            </p>

            <div class="flex gap-5 mt-10">
                <a href="#products" class="px-8 py-4 bg-red-600 rounded-full font-bold hover:scale-105 transition">
                    Shop Collection
                </a>
                <a href="#" class="px-8 py-4 border border-white/20 rounded-full font-bold hover:bg-white hover:text-black transition">
                    Explore Drops
                </a>
            </div>
        </div>

        <div class="relative">
            <div class="absolute inset-0 bg-red-600 blur-[120px] opacity-30"></div>

            <div class="relative w-[360px] md:w-[520px] h-[520px] rounded-[3rem] bg-white/10 border border-white/20 backdrop-blur-xl flex items-center justify-center shadow-2xl rotate-3 hover:rotate-0 transition duration-500">
                <img 
                    src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?q=80&w=1200&auto=format&fit=crop"
                    class="w-[85%] rotate-[-25deg] drop-shadow-[0_40px_60px_rgba(0,0,0,0.8)] hover:scale-110 transition duration-500"
                >
            </div>
        </div>

    </section>

    <section class="px-10 py-16 grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="p-6 rounded-3xl bg-white/10 border border-white/10 hover:bg-red-600 transition">
            <h3 class="text-2xl font-bold">Running</h3>
            <p class="text-gray-300 text-sm mt-2">Lightweight speed pairs</p>
        </div>

        <div class="p-6 rounded-3xl bg-white/10 border border-white/10 hover:bg-blue-600 transition">
            <h3 class="text-2xl font-bold">Streetwear</h3>
            <p class="text-gray-300 text-sm mt-2">Daily flex collection</p>
        </div>

        <div class="p-6 rounded-3xl bg-white/10 border border-white/10 hover:bg-purple-600 transition">
            <h3 class="text-2xl font-bold">Basketball</h3>
            <p class="text-gray-300 text-sm mt-2">Court-ready power</p>
        </div>

        <div class="p-6 rounded-3xl bg-white/10 border border-white/10 hover:bg-yellow-500 hover:text-black transition">
            <h3 class="text-2xl font-bold">Limited</h3>
            <p class="text-gray-300 text-sm mt-2">Rare premium drops</p>
        </div>
    </section>

    <section id="products" class="px-10 py-20">
        <div class="flex items-end justify-between mb-12">
            <div>
                <p class="text-red-500 font-bold tracking-[0.3em]">SHOP NOW</p>
                <h2 class="text-5xl font-black mt-3">Featured Sneakers</h2>
            </div>
            <p class="text-gray-400 hidden md:block">Premium picks for your next flex.</p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">

            <% products.forEach(function(product){ %>
                <div 
                    class="group p-5 rounded-[2rem] border border-white/10 backdrop-blur-xl hover:-translate-y-3 transition duration-300"
                    style="background-color:<%= product.panelcolor || '#111827' %>;"
                >
                    <div 
                        class="h-56 rounded-[1.5rem] overflow-hidden flex items-center justify-center"
                        style="background-color:<%= product.bgcolor || '#000000' %>;"
                    >
                        <img 
                            src="data:<%= product.mimetype || 'image/png'%> ; base64,<%= product.image %>"  
                            class="w-full h-full object-cover group-hover:scale-110 transition duration-500"
                        >

                    </div>

                    <div class="mt-5 flex items-center justify-between">
                        <div>
                            <h3 
                                class="text-xl font-bold"
                                style="color:<%= product.textcolor || '#ffffff' %>;"
                            >
                                <%= product.name %>
                            </h3>

                            <% if(product.discount > 0){ %>
                                <p class="text-red-400 font-bold mt-1">
                                    ₹<%= Math.floor(product.price - (product.price * product.discount / 100)) %>
                                </p>

                                <p class="text-gray-400 line-through text-sm">
                                    ₹<%= product.price %>
                                </p>
                            <% } else { %>
                                <p class="text-red-400 font-bold mt-1">
                                    ₹<%= product.price %>
                                </p>
                            <% } %>
                        </div>

                        <form action="/cart/add/<%= product._id %>" method="POST">
                            <button class="w-12 h-12 rounded-full bg-white text-black font-black hover:bg-red-600 hover:text-white transition">
                                +
                            </button>
                        </form>
                    </div>
                </div>
            <% }) %>

        </div>
    </section>

    <section class="mx-10 my-20 p-10 md:p-16 rounded-[3rem] bg-gradient-to-r from-red-700 via-black to-blue-700 border border-white/20">
        <div class="max-w-2xl">
            <p class="font-bold tracking-[0.3em] text-white/70">LIMITED OFFER</p>
            <h2 class="text-5xl md:text-6xl font-black mt-4">
                Get 30% Off On First Flex
            </h2>
            <p class="text-gray-300 mt-5">
                Join SneakyFlex and unlock premium sneaker deals before everyone else.
            </p>
            <button class="mt-8 px-8 py-4 bg-white text-black rounded-full font-bold hover:scale-105 transition">
                Claim Offer
            </button>
        </div>
    </section>


    <footer class="px-10 py-10 border-t border-white/10 text-gray-400 flex flex-col md:flex-row justify-between gap-4">
        <p>© 2026 SneakyFlex. All rights reserved.</p>
        <div class="flex gap-6">
            <a href="#" class="hover:text-white">Instagram</a>
            <a href="#" class="hover:text-white">Twitter</a>
            <a href="#" class="hover:text-white">Contact</a>
        </div>
    </footer>

</body>
</html>