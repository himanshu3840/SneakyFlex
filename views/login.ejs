<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SneakyFlex | Login</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<script>
  setTimeout(() => {
    const flash = document.getElementById("flash-message");
    if (flash) {
      flash.style.display = "none";
    }
  }, 3000);
</script>

<body class="min-h-screen bg-zinc-950 text-white overflow-hidden">


  
  <div class="absolute inset-0">
    <div class="absolute -top-32 -left-32 w-96 h-96 bg-blue-600/30 rounded-full blur-3xl"></div>
    <div class="absolute top-40 -right-32 w-96 h-96 bg-purple-600/25 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-1/3 w-96 h-96 bg-cyan-500/20 rounded-full blur-3xl"></div>
  </div>

  <div class="relative min-h-screen flex items-center justify-center px-6">

    <div class="w-full max-w-6xl grid md:grid-cols-2 bg-white/10 backdrop-blur-xl border border-white/10 rounded-3xl overflow-hidden shadow-2xl">

      <div class="hidden md:flex flex-col justify-between p-12 bg-gradient-to-br from-zinc-900 via-zinc-950 to-black">
        <div>
          <h1 class="text-4xl font-black tracking-tight">
            Sneaky<span class="text-blue-500">Flex</span>
          </h1>
          <p class="mt-3 text-zinc-400">
            Premium sneakers for people who move different.
          </p>
        </div>

        <div class="relative flex justify-center">
          <div class="absolute w-72 h-72 bg-blue-500/20 rounded-full blur-3xl"></div>
          <img
            src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=900"
            class="relative w-[430px] -rotate-12 drop-shadow-2xl"
            alt="Sneaker"
          />
        </div>

        <div class="flex gap-3 text-sm text-zinc-400">
          <span class="px-4 py-2 bg-white/10 rounded-full">Limited Drops</span>
          <span class="px-4 py-2 bg-white/10 rounded-full">Streetwear</span>
          <span class="px-4 py-2 bg-white/10 rounded-full">Premium Fit</span>
        </div>
      </div>

      <div class="p-8 md:p-14 flex items-center">
        <div class="w-full max-w-md mx-auto">
          <h2 class="text-3xl font-bold">Welcome back</h2>
          <p class="text-zinc-400 mt-2">Login to continue your SneakyFlex journey.</p>

          <% if (error && error.length > 0) { %>
            <div id="flash-message" class="mt-5 px-4 py-3 rounded-xl bg-red-500/10 border border-red-500/30 text-red-400 text-sm">
              <%= error[0] %>
            </div>
          <% } %>


          <form action="/users/login" method="POST" class="mt-8 space-y-5">

            <div>
              <label class="text-sm text-zinc-300">Email</label>
              <input
                type="email"
                name="email"
                placeholder="Enter your email"
                class="mt-2 w-full px-4 py-3 rounded-xl bg-white/10 border border-white/10 outline-none focus:border-blue-500 focus:bg-white/15 placeholder:text-zinc-500"
              />
            </div>

            <div>
              <label class="text-sm text-zinc-300">Password</label>
              <input
                type="password"
                name="password"
                placeholder="Enter your password"
                class="mt-2 w-full px-4 py-3 rounded-xl bg-white/10 border border-white/10 outline-none focus:border-blue-500 focus:bg-white/15 placeholder:text-zinc-500"
              />
            </div>

            <div class="flex items-center justify-between text-sm">
              <label class="flex items-center gap-2 text-zinc-400">
                <input type="checkbox" class="accent-blue-500">
                Remember me
              </label>
              <a href="#" class="text-blue-400 hover:text-blue-300">Forgot password?</a>
            </div>

            <button
              type="submit"
              class="w-full py-3 rounded-xl bg-blue-600 hover:bg-blue-500 font-semibold transition shadow-lg shadow-blue-600/30">
              Login
            </button>

          </form>

          <p class="mt-6 text-center text-zinc-400 text-sm">
            New to SneakyFlex?
            <a href="/register" class="text-blue-400 hover:text-blue-300 font-medium">Create account</a>
          </p>
        </div>
      </div>

    </div>

  </div>

</body>
</html>